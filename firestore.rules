rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Хэрэглэгч зөвхөн өөрийн төслүүдэд ханддаг
    match /users/{uid}/projects/{projectId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }
    // AI хэрэглээний тоолуур — зөвхөн сервер (Cloud Function admin) бичнэ
    match /aiUsage/{docId} {
      allow read, write: if false;
    }
    // Бусад бүх зам хаалттай
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
